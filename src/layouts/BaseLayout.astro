---
import "@/styles/global.css";

const {
  title = "KitaCuan",
  description = "Web app catat pemasukan dan pengeluaran dengan vibe cepat, ringan, dan rapi."
} = Astro.props;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#ec6641" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:wght@500;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        const storageKey = "kitacuan-theme";
        const root = document.documentElement;
        const media = window.matchMedia("(prefers-color-scheme: dark)");
        const metaTheme = document.querySelector('meta[name="theme-color"]');

        const applyTheme = (theme) => {
          const isDark = theme === "dark";
          root.classList.toggle("dark", isDark);
          root.style.colorScheme = isDark ? "dark" : "light";
          metaTheme?.setAttribute("content", isDark ? "#10131c" : "#f4f1fb");
        };

        const resolveTheme = () => {
          const saved = localStorage.getItem(storageKey);
          if (saved === "light" || saved === "dark") {
            return saved;
          }

          return media.matches ? "dark" : "light";
        };

        applyTheme(resolveTheme());

        window.__kitacuanTheme = {
          get: resolveTheme,
          set: (theme) => {
            localStorage.setItem(storageKey, theme);
            applyTheme(theme);
          },
          clear: () => {
            localStorage.removeItem(storageKey);
            applyTheme(resolveTheme());
          }
        };

        media.addEventListener("change", () => {
          if (!localStorage.getItem(storageKey)) {
            applyTheme(resolveTheme());
          }
        });

        window.addEventListener("DOMContentLoaded", () => {
          document.querySelectorAll("[data-theme-toggle]").forEach((button) => {
            button.addEventListener("click", () => {
              const next = root.classList.contains("dark") ? "light" : "dark";
              window.__kitacuanTheme?.set(next);
            });
          });
        });
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
