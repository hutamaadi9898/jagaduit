---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import MerchantLogo from "@/components/app/merchant-logo.astro";
import RouteErrorState from "@/components/app/route-error-state.astro";
import TransactionListItem from "@/components/app/transaction-list-item.astro";
import { listCommonMerchantBrands } from "@/lib/merchant-brands";
import { formatCompactCurrency, formatDateLabel, formatMonthLabel, monthFromDate } from "@/lib/utils";
import { getDb } from "@/server/db/client";
import { logError } from "@/server/observability";
import { listAccounts } from "@/server/repositories/accounts";
import { listCategories } from "@/server/repositories/categories";
import { listTransactions } from "@/server/repositories/transactions";
import { transactionFiltersSchema } from "@/server/validation";
import type { Account, Category, TransactionWithRelations } from "@/types/app";

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const filters = transactionFiltersSchema.parse({
  month: Astro.url.searchParams.get("month") ?? monthFromDate(),
  kind: Astro.url.searchParams.get("kind") ?? "all",
  accountId: Astro.url.searchParams.get("accountId") ?? undefined,
  categoryId: Astro.url.searchParams.get("categoryId") ?? undefined,
  query: Astro.url.searchParams.get("query") ?? undefined
});

const db = getDb(Astro.locals);
let accounts: Account[] = [];
let categories: Category[] = [];
let transactions: TransactionWithRelations[] = [];
let loadError: string | null = null;

try {
  accounts = await listAccounts(db, Astro.locals.user.id, false);
  categories = await listCategories(db, Astro.locals.user.id, false);
  transactions = await listTransactions(db, Astro.locals.user.id, filters);
} catch (error) {
  loadError = "Histori transaksi belum bisa dimuat dari D1.";
  logError("transactions_page_load_failed", error, {
    userId: Astro.locals.user.id,
    month: filters.month
  });
}

const groupedTransactions = Object.entries(
  transactions.reduce<Record<string, typeof transactions>>((acc, transaction) => {
    acc[transaction.transactionDate] ??= [];
    acc[transaction.transactionDate].push(transaction);
    return acc;
  }, {})
);

const totalIncome = transactions
  .filter((item) => item.kind === "income")
  .reduce((sum, item) => sum + item.amountMinor, 0);
const totalExpense = transactions
  .filter((item) => item.kind === "expense")
  .reduce((sum, item) => sum + item.amountMinor, 0);
const netFlow = totalIncome - totalExpense;
const merchantCatalog = listCommonMerchantBrands().slice(0, 18).map((merchant) => ({
  ...merchant,
  label: merchant.name,
  matchSource: "brand" as const
}));
---

<BaseLayout title="Transaksi | KitaCuan">
  <AppLayout title="Report transaksi" currentPath={Astro.url.pathname}>
    {
      loadError ? (
        <RouteErrorState title="Histori lagi gangguan" message={loadError} />
      ) : (
        <section class="grid gap-4">
          <div class="grid gap-4 lg:grid-cols-[1.02fr_0.98fr]">
            <div class="hero-aurora relative overflow-hidden rounded-[2.2rem] px-5 py-5 text-white">
              <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.24),transparent_30%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.12),transparent_25%)]"></div>
              <div class="relative">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/75">Monthly report</p>
                    <h2 class="mt-2 text-3xl font-bold">{formatMonthLabel(filters.month)}</h2>
                  </div>
                  <span class="data-pill">{transactions.length} entries</span>
                </div>

                <div class="mt-8 grid gap-3 sm:grid-cols-3">
                  <div class="rounded-[1.4rem] bg-white/14 px-4 py-3 backdrop-blur">
                    <p class="text-xs text-white/75">Income</p>
                    <p class="mt-2 text-xl font-bold">{formatCompactCurrency(totalIncome)}</p>
                  </div>
                  <div class="rounded-[1.4rem] bg-white/14 px-4 py-3 backdrop-blur">
                    <p class="text-xs text-white/75">Expense</p>
                    <p class="mt-2 text-xl font-bold">{formatCompactCurrency(totalExpense)}</p>
                  </div>
                  <div class="rounded-[1.4rem] bg-white/14 px-4 py-3 backdrop-blur">
                    <p class="text-xs text-white/75">Net</p>
                    <p class="mt-2 text-xl font-bold">{formatCompactCurrency(netFlow)}</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="soft-section">
              <div class="flex items-center justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary/55">Filters</p>
                  <h3 class="mt-2 text-xl font-bold text-foreground">Tune the view</h3>
                </div>
                <a href="/app/transactions/new" class="frost-pill">
                  Add new
                </a>
              </div>

              <form class="mt-4 grid gap-3 sm:grid-cols-2" method="GET">
                <input
                  class="h-12 rounded-[1.2rem] border border-border bg-card/80 px-4 text-sm"
                  type="month"
                  name="month"
                  value={filters.month}
                />
                <select
                  class="h-12 rounded-[1.2rem] border border-border bg-card/80 px-4 text-sm"
                  name="kind"
                >
                  <option value="all" selected={filters.kind === "all"}>Semua</option>
                  <option value="expense" selected={filters.kind === "expense"}>Pengeluaran</option>
                  <option value="income" selected={filters.kind === "income"}>Pemasukan</option>
                </select>
                <select
                  class="h-12 rounded-[1.2rem] border border-border bg-card/80 px-4 text-sm"
                  name="accountId"
                >
                  <option value="">Semua akun</option>
                  {accounts.map((account) => <option value={account.id} selected={filters.accountId === account.id}>{account.name}</option>)}
                </select>
                <select
                  class="h-12 rounded-[1.2rem] border border-border bg-card/80 px-4 text-sm"
                  name="categoryId"
                >
                  <option value="">Semua kategori</option>
                  {categories.map((category) => <option value={category.id} selected={filters.categoryId === category.id}>{category.name}</option>)}
                </select>
                <input
                  class="h-12 rounded-[1.2rem] border border-border bg-card/80 px-4 text-sm sm:col-span-2"
                  type="search"
                  name="query"
                  value={filters.query}
                  placeholder="Cari catatan atau pola transaksi"
                />
                <button class="h-12 rounded-[1.2rem] bg-[linear-gradient(135deg,#8c65f1,#b18cf8)] px-4 text-sm font-semibold text-white shadow-[0_12px_28px_rgba(140,101,241,0.24)] sm:col-span-2">
                  Terapkan filter
                </button>
              </form>
            </div>
          </div>

          <div class="soft-section">
            <div class="flex items-start justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary/55">Merchant atlas</p>
                <h3 class="mt-2 text-xl font-bold text-foreground">Common Gen Z picks</h3>
                <p class="mt-1 text-sm text-muted-foreground">
                  Wallet, commerce, coffee, convenience, and fast-food brands ready for automatic matching.
                </p>
              </div>
              <span class="frost-pill">{merchantCatalog.length} brands</span>
            </div>

            <div class="merchant-chip-grid mt-4">
              {merchantCatalog.map((merchant) => (
                <div class="merchant-chip">
                  <MerchantLogo merchant={merchant} size="sm" />
                  <div class="min-w-0">
                    <p class="truncate text-sm font-semibold text-foreground">{merchant.name}</p>
                    <p class="truncate text-[11px] uppercase tracking-[0.14em] text-muted-foreground">
                      {merchant.category}
                    </p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          {
            groupedTransactions.length === 0 ? (
              <div class="soft-section text-center text-muted-foreground">
                <p class="font-semibold text-foreground">Belum ada transaksi untuk filter ini.</p>
                <p class="mt-2">Coba ganti filter atau tambah transaksi baru supaya report mulai terisi.</p>
                <a
                  class="app-solid-button mt-4 text-xs"
                  href="/app/transactions/new"
                >
                  Tambah transaksi
                </a>
              </div>
            ) : (
              groupedTransactions.map(([date, items]) => (
                <div class="soft-section">
                  <div class="flex items-center justify-between gap-3">
                    <div>
                      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary/55">Daily log</p>
                      <h3 class="mt-2 text-xl font-bold text-foreground">{formatDateLabel(date)}</h3>
                    </div>
                    <span class="frost-pill">{items.length} items</span>
                  </div>

                  <div class="mt-4 space-y-3">
                    {items.map((item) => (
                      <TransactionListItem
                        item={item}
                        href={`/app/transactions/new?edit=${item.id}`}
                        showActions
                      />
                    ))}
                  </div>
                </div>
              ))
            )
          }
        </section>
      )
    }
  </AppLayout>
</BaseLayout>
