---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import { ExpenseChart } from "@/components/app/expense-chart";
import RouteErrorState from "@/components/app/route-error-state.astro";
import TransactionListItem from "@/components/app/transaction-list-item.astro";
import { Badge } from "@/components/ui/badge";
import { formatCompactCurrency, formatCurrency, formatMonthLabel, monthFromDate } from "@/lib/utils";
import { getDb, getKv } from "@/server/db/client";
import { logError } from "@/server/observability";
import { listTransactions } from "@/server/repositories/transactions";
import { getDashboardSummary } from "@/server/services/dashboard";
import type { DashboardSummary, TransactionWithRelations } from "@/types/app";

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const month = Astro.url.searchParams.get("month") ?? monthFromDate();
const db = getDb(Astro.locals);
const kv = getKv(Astro.locals);
let summary: DashboardSummary | null = null;
let recentTransactions: TransactionWithRelations[] = [];
let loadError: string | null = null;

try {
  summary = await getDashboardSummary(db, kv, Astro.locals.user.id, month);
  recentTransactions = (
    await listTransactions(db, Astro.locals.user.id, { month, kind: "all" })
  ).slice(0, 5);
} catch (error) {
  loadError = "Ringkasan bulan ini belum bisa dimuat dari D1 atau KV.";
  logError("dashboard_page_load_failed", error, { userId: Astro.locals.user.id, month });
}

const reportItems = summary?.topCategories.slice(0, 4) ?? [];
let reportGradient =
  "conic-gradient(rgba(140,101,241,0.12) 0 100%, rgba(140,101,241,0.12) 100% 100%)";

if (summary && summary.totalExpense > 0 && reportItems.length > 0) {
  let current = 0;
  const segments = reportItems.map((item) => {
    const share = (item.total / summary.totalExpense) * 100;
    const next = Math.min(current + share, 100);
    const segment = `${item.color} ${current}% ${next}%`;
    current = next;
    return segment;
  });

  if (current < 100) {
    segments.push(`rgba(215, 213, 226, 0.72) ${current}% 100%`);
  }

  reportGradient = `conic-gradient(${segments.join(", ")})`;
}

const topCategory = summary?.topCategories[0] ?? null;
const totalFlow = summary ? summary.totalIncome + summary.totalExpense : 0;
const expenseShare = totalFlow > 0 && summary ? Math.round((summary.totalExpense / totalFlow) * 100) : 0;
const insightMessage = summary
  ? summary.netBalance >= 0
    ? `Saldo bulan ini masih surplus ${formatCompactCurrency(summary.netBalance)}.`
    : `Pengeluaran lewat ${formatCompactCurrency(Math.abs(summary.netBalance))} dari pemasukan bulan ini.`
  : "";
---

<BaseLayout title="Ringkasan | KitaCuan">
  <AppLayout title={`Halo, ${Astro.locals.user.displayName}`} currentPath={Astro.url.pathname}>
    {
      loadError || !summary ? (
        <RouteErrorState
          title="Dashboard lagi gangguan"
          message={loadError ?? "Ringkasan belum bisa dimuat saat ini."}
        />
      ) : (
        <section class="grid gap-4 lg:grid-cols-[1.08fr_0.92fr]">
          <div class="grid gap-4">
            <article class="hero-aurora relative overflow-hidden rounded-[2.15rem] px-5 py-5 text-white sm:px-6">
              <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.28),transparent_28%),radial-gradient(circle_at_bottom_right,rgba(255,255,255,0.12),transparent_24%)]"></div>
              <div class="relative">
                <div class="flex items-center justify-between gap-3">
                  <span class="data-pill">{formatMonthLabel(month)}</span>
                  <span class="rounded-full border border-white/30 bg-white/14 px-3 py-1 text-[11px] font-semibold text-white/88">
                    Live sync
                  </span>
                </div>

                <div class="mt-7">
                  <p class="text-sm text-white/74">Current balance</p>
                  <h2 class="mt-2 text-4xl font-bold tracking-[-0.05em] sm:text-[3.2rem]">
                    {formatCurrency(summary.netBalance)}
                  </h2>
                  <p class="mt-3 max-w-sm text-sm leading-6 text-white/80">
                    {topCategory
                      ? `${topCategory.name} masih kategori paling berat untuk ${formatMonthLabel(month)}.`
                      : "Transaksi pertama akan langsung menghidupkan insight dashboard."}
                  </p>
                </div>
              </div>
            </article>

            <div class="grid gap-3 sm:grid-cols-2">
              <div class="metric-tile">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-secondary">Money in</p>
                    <p class="mt-2 text-2xl font-bold">{formatCurrency(summary.totalIncome)}</p>
                  </div>
                  <span class="rounded-full bg-secondary/14 px-3 py-1 text-xs font-semibold text-secondary-foreground">
                    Income
                  </span>
                </div>
              </div>

              <div class="metric-tile">
                <div class="flex items-center justify-between gap-3">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-destructive">Money out</p>
                    <p class="mt-2 text-2xl font-bold">{formatCurrency(summary.totalExpense)}</p>
                  </div>
                  <span class="rounded-full bg-destructive/12 px-3 py-1 text-xs font-semibold text-destructive">
                    {expenseShare}% flow
                  </span>
                </div>
              </div>
            </div>

            <div class="insight-banner flex items-center justify-between gap-3">
              <div>
                <p class="text-sm font-semibold">Your insight is ready</p>
                <p class="insight-banner__meta text-xs">{insightMessage}</p>
              </div>
              <a
                href="/app/transactions/new"
                class="insight-banner__action"
              >
                Add entry
              </a>
            </div>

            <div class="soft-section">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary/55">Transactions</p>
                  <h3 class="mt-2 text-xl font-bold text-foreground">Latest activity</h3>
                  <p class="mt-1 text-sm text-muted-foreground">
                    {recentTransactions.length > 0
                      ? `Total flow ${formatCurrency(totalFlow)} for ${formatMonthLabel(month)}.`
                      : "Belum ada aktivitas untuk bulan aktif."}
                  </p>
                </div>
                <a href="/app/transactions" class="frost-pill">
                  View all
                </a>
              </div>

              <div class="mt-4 space-y-3">
                {
                  recentTransactions.length === 0 ? (
                    <div class="list-tile text-sm text-muted-foreground">
                      <p class="font-semibold text-foreground">Belum ada transaksi tercatat.</p>
                      <p class="mt-1">Mulai dari satu catatan kecil supaya halaman home langsung terasa hidup.</p>
                    </div>
                  ) : (
                    recentTransactions.map((item) => (
                      <TransactionListItem
                        item={item}
                        href={`/app/transactions/new?edit=${item.id}`}
                        amountMode="compact"
                      />
                    ))
                  )
                }
              </div>
            </div>
          </div>

          <div class="grid gap-4">
            <div class="soft-section">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary/55">Report</p>
                  <h3 class="mt-2 text-xl font-bold text-foreground">Expense mix</h3>
                  <p class="mt-1 text-sm text-muted-foreground">Kategori paling dominan untuk pengeluaran bulan aktif.</p>
                </div>
                <Badge>Expenses</Badge>
              </div>

              {
                reportItems.length === 0 ? (
                  <div class="mt-5 list-tile text-sm text-muted-foreground">
                    Belum ada pengeluaran bulan ini, jadi ring report belum terbentuk.
                  </div>
                ) : (
                  <>
                    <div class="mt-6 flex justify-center">
                      <div
                        class="relative flex h-56 w-56 items-center justify-center rounded-full"
                        style={`background:${reportGradient}`}
                      >
                        <div class="flex h-[8.5rem] w-[8.5rem] flex-col items-center justify-center rounded-full bg-white/94 text-center shadow-[inset_0_1px_0_rgba(255,255,255,0.8)]">
                          <p class="text-xs font-medium uppercase tracking-[0.18em] text-muted-foreground">Expenses</p>
                          <p class="mt-2 text-2xl font-bold text-foreground">{formatCompactCurrency(summary.totalExpense)}</p>
                        </div>
                      </div>
                    </div>

                    <div class="mt-5 space-y-3">
                      {reportItems.map((item) => {
                        const share = summary.totalExpense > 0 ? (item.total / summary.totalExpense) * 100 : 0;

                        return (
                          <div class="list-tile">
                            <div class="flex items-center justify-between gap-3">
                              <div class="flex items-center gap-3">
                                <span class="h-3 w-3 rounded-full" style={`background:${item.color}`}></span>
                                <div>
                                  <p class="font-semibold text-foreground">{item.name}</p>
                                  <p class="text-xs text-muted-foreground">{Math.round(share)}% of total</p>
                                </div>
                              </div>
                              <p class="font-semibold text-foreground">{formatCompactCurrency(item.total)}</p>
                            </div>
                            <div class="mt-3 h-2 rounded-full bg-muted">
                              <div
                                class="h-2 rounded-full"
                                style={`width:${Math.max(share, 6)}%; background:${item.color}`}
                              ></div>
                            </div>
                          </div>
                        );
                      })}
                    </div>
                  </>
                )
              }
            </div>

            <div class="soft-section">
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary/55">Pulse</p>
                  <h3 class="mt-2 text-xl font-bold text-foreground">Daily spending</h3>
                  <p class="mt-1 text-sm text-muted-foreground">Ritme pengeluaran sepanjang bulan ini.</p>
                </div>
                <span class="frost-pill">{formatMonthLabel(month)}</span>
              </div>

              <div class="mt-5">
                {
                  recentTransactions.length === 0 ? (
                    <div class="list-tile text-sm text-muted-foreground">
                      Tambah transaksi dulu supaya daily pulse mulai kelihatan.
                    </div>
                  ) : (
                    <ExpenseChart data={summary.dailySeries} client:load />
                  )
                }
              </div>
            </div>
          </div>
        </section>
      )
    }
  </AppLayout>
</BaseLayout>
