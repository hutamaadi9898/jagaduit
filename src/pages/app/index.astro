---
import BaseLayout from "@/layouts/BaseLayout.astro";
import AppLayout from "@/layouts/AppLayout.astro";
import { ExpenseChart } from "@/components/app/expense-chart";
import RouteErrorState from "@/components/app/route-error-state.astro";
import { Badge } from "@/components/ui/badge";
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from "@/components/ui/card";
import { formatCompactCurrency, formatCurrency, formatMonthLabel, monthFromDate } from "@/lib/utils";
import { getDb, getKv } from "@/server/db/client";
import { logError } from "@/server/observability";
import { listTransactions } from "@/server/repositories/transactions";
import { getDashboardSummary } from "@/server/services/dashboard";
import type { DashboardSummary, TransactionWithRelations } from "@/types/app";

if (!Astro.locals.user) {
  return Astro.redirect("/login");
}

const month = Astro.url.searchParams.get("month") ?? monthFromDate();
const db = getDb(Astro.locals);
const kv = getKv(Astro.locals);
let summary: DashboardSummary | null = null;
let recentTransactions: TransactionWithRelations[] = [];
let loadError: string | null = null;

try {
  summary = await getDashboardSummary(db, kv, Astro.locals.user.id, month);
  recentTransactions = (await listTransactions(db, Astro.locals.user.id, { month, kind: "all" })).slice(0, 5);
} catch (error) {
  loadError = "Ringkasan bulan ini belum bisa dimuat dari D1 atau KV.";
  logError("dashboard_page_load_failed", error, { userId: Astro.locals.user.id, month });
}
---

<BaseLayout title="Ringkasan | KitaCuan">
  <AppLayout title={`Halo, ${Astro.locals.user.displayName}`} currentPath={Astro.url.pathname}>
    {
      loadError || !summary ? (
        <RouteErrorState
          title="Dashboard lagi gangguan"
          message={loadError ?? "Ringkasan belum bisa dimuat saat ini."}
        />
      ) : (
    <section class="grid gap-4 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="grid gap-4">
        <Card className="overflow-hidden">
          <CardHeader>
            <Badge>Live bulan ini</Badge>
            <CardTitle className="mt-3 text-4xl">Saldo bersih <span class="headline-balance">{formatCompactCurrency(summary.netBalance)}</span></CardTitle>
            <CardDescription>{formatMonthLabel(month)} • pantau uang masuk dan keluar tanpa buka spreadsheet.</CardDescription>
          </CardHeader>
          <CardContent className="grid gap-3 sm:grid-cols-3">
            <div class="rounded-[1.6rem] bg-primary/8 p-4">
              <p class="text-sm font-semibold text-primary">Pemasukan</p>
              <p class="mt-2 text-2xl font-bold">{formatCurrency(summary.totalIncome)}</p>
            </div>
            <div class="rounded-[1.6rem] bg-destructive/8 p-4">
              <p class="text-sm font-semibold text-destructive">Pengeluaran</p>
              <p class="mt-2 text-2xl font-bold">{formatCurrency(summary.totalExpense)}</p>
            </div>
            <div class="rounded-[1.6rem] bg-secondary/16 p-4">
              <p class="text-sm font-semibold text-foreground">Neraca</p>
              <p class="mt-2 text-2xl font-bold">{formatCurrency(summary.netBalance)}</p>
            </div>
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>Tren pengeluaran harian</CardTitle>
            <CardDescription>Lihat ritme belanja di bulan aktif.</CardDescription>
          </CardHeader>
          <CardContent>
            {
              recentTransactions.length === 0 ? (
                <div class="rounded-[1.6rem] bg-muted px-4 py-8 text-sm text-muted-foreground">
                  <p class="font-semibold text-foreground">Belum ada data untuk divisualkan.</p>
                  <p class="mt-2">Mulai dari satu pemasukan atau pengeluaran supaya grafik bulan ini kebentuk.</p>
                  <a class="mt-4 inline-flex rounded-full bg-foreground px-4 py-2 text-xs font-semibold text-white" href="/app/transactions/new">
                    Mulai logging
                  </a>
                </div>
              ) : (
                <ExpenseChart data={summary.dailySeries} client:load />
              )
            }
          </CardContent>
        </Card>
      </div>

      <div class="grid gap-4">
        <Card>
          <CardHeader>
            <CardTitle>Kategori paling berat</CardTitle>
            <CardDescription>Top 5 pengeluaran bulan ini.</CardDescription>
          </CardHeader>
          <CardContent className="space-y-3">
            {
              summary.topCategories.length === 0 ? (
                <div class="rounded-[1.4rem] bg-muted px-4 py-5 text-sm text-muted-foreground">
                  <p class="font-semibold text-foreground">Belum ada pengeluaran tercatat untuk bulan ini.</p>
                  <p class="mt-2">Catat transaksi pertama supaya kategori yang paling berat mulai kelihatan.</p>
                </div>
              ) : (
                summary.topCategories.map((item) => (
                  <div class="flex items-center justify-between rounded-[1.4rem] bg-muted/70 px-4 py-3">
                    <div class="flex items-center gap-3">
                      <span class="h-3 w-3 rounded-full" style={`background:${item.color}`}></span>
                      <div>
                        <p class="font-semibold">{item.name}</p>
                        <p class="text-xs text-muted-foreground">{item.icon}</p>
                      </div>
                    </div>
                    <p class="font-semibold">{formatCurrency(item.total)}</p>
                  </div>
                ))
              )
            }
          </CardContent>
        </Card>

        <Card>
          <CardHeader>
            <CardTitle>Transaksi terbaru</CardTitle>
            <CardDescription>Ringkas, langsung kelihatan.</CardDescription>
          </CardHeader>
          <CardContent className="space-y-3">
            {
              recentTransactions.length === 0 ? (
                <div class="rounded-[1.4rem] bg-muted px-4 py-5 text-sm text-muted-foreground">
                  <p class="font-semibold text-foreground">Belum ada transaksi.</p>
                  <p class="mt-2">Mulai dari satu catatan kecil hari ini, lalu dashboard bakal ikut hidup.</p>
                  <a class="mt-4 inline-flex rounded-full bg-primary px-4 py-2 text-xs font-semibold text-primary-foreground" href="/app/transactions/new">
                    Start logging
                  </a>
                </div>
              ) : (
                recentTransactions.map((item) => (
                  <a href={`/app/transactions/new?edit=${item.id}`} class="flex items-center justify-between rounded-[1.4rem] bg-muted/70 px-4 py-3 hover:bg-white">
                    <div>
                      <p class="font-semibold">{item.categoryName}</p>
                      <p class="text-xs text-muted-foreground">{item.accountName} • {item.transactionDate}</p>
                    </div>
                    <p class:list={["font-semibold", item.kind === "income" ? "text-green-600" : "text-destructive"]}>
                      {item.kind === "income" ? "+" : "-"}{formatCompactCurrency(item.amountMinor)}
                    </p>
                  </a>
                ))
              )
            }
          </CardContent>
        </Card>
      </div>
    </section>
      )
    }
  </AppLayout>
</BaseLayout>
