---
import { ArrowRight, Sparkles, WalletCards } from "lucide-react";

import BaseLayout from "@/layouts/BaseLayout.astro";
import { APP_NAME } from "@/server/constants/categories";
---

<BaseLayout
  title={`${APP_NAME} | Expense tracker gen-z Indonesia`}
  description="Catat pemasukan dan pengeluaran dengan flow cepat, tampilan bold, dan dashboard ringan untuk harian."
>
  <main class="relative overflow-hidden px-4 pb-12 pt-6 sm:px-6">
    <div class="noise-overlay absolute inset-0"></div>
    <div class="shell-grid absolute inset-x-0 top-24 h-80 opacity-60"></div>
    <div class="relative mx-auto flex max-w-6xl flex-col gap-8">
      <header class="glass-card flex items-center justify-between rounded-[2rem] px-5 py-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.28em] text-primary/70">{APP_NAME}</p>
          <h1 class="mt-2 text-2xl font-bold sm:text-3xl">Biar duit nggak cuma lewat, tapi kebaca.</h1>
        </div>
        <a class="rounded-full bg-foreground px-4 py-2 text-sm font-semibold text-white" href="/login">Masuk</a>
      </header>

      <section class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="glass-card relative overflow-hidden rounded-[2.4rem] p-6 sm:p-8">
          <div class="absolute -right-12 top-0 h-40 w-40 rounded-full bg-primary/20 blur-3xl"></div>
          <div class="absolute bottom-0 left-0 h-40 w-40 rounded-full bg-secondary/25 blur-3xl"></div>
          <div class="relative">
            <p class="inline-flex items-center gap-2 rounded-full bg-white/80 px-3 py-1 text-xs font-semibold text-primary">
              <Sparkles className="h-4 w-4" />
              MVP buat Gen-Z Indonesia
            </p>
            <h2 class="mt-5 max-w-xl text-5xl font-bold leading-none sm:text-6xl">
              Track <span class="headline-balance">cashflow</span> tanpa ribet.
            </h2>
            <p class="mt-5 max-w-lg text-base text-muted-foreground sm:text-lg">
              KitaCuan bantu kamu catat pengeluaran, pemasukan, kategori favorit, dan ritme bulanan tanpa dashboard yang terasa kaku.
            </p>
            <div class="mt-8 flex flex-col gap-3 sm:flex-row">
              <a
                class="inline-flex items-center justify-center gap-2 rounded-[1.3rem] bg-primary px-5 py-4 font-semibold text-primary-foreground shadow-[0_18px_40px_rgba(236,102,65,0.25)]"
                href="/register"
              >
                Coba Gratis
                <ArrowRight className="h-4 w-4" />
              </a>
              <a class="inline-flex items-center justify-center rounded-[1.3rem] border border-border bg-white/80 px-5 py-4 font-semibold" href="/login">
                Sudah punya akun
              </a>
            </div>
          </div>
        </div>

        <div class="grid gap-4">
          <article class="glass-card rounded-[2rem] p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary/70">Daily speed</p>
            <p class="mt-3 text-3xl font-bold">Tambah transaksi dalam hitungan detik.</p>
            <p class="mt-2 text-sm text-muted-foreground">Flow mobile-first, angka langsung IDR, kategori starter Indonesia, dan akun utama siap pakai.</p>
          </article>
          <article class="rounded-[2rem] border border-foreground/10 bg-foreground p-5 text-white">
            <div class="flex items-center justify-between">
              <span class="rounded-full bg-white/10 px-3 py-1 text-xs font-semibold">Ringan</span>
              <WalletCards className="h-5 w-5 text-secondary" />
            </div>
            <p class="mt-8 text-4xl font-bold">IDR only.</p>
            <p class="mt-2 text-sm text-white/70">Fokus dulu ke kebutuhan lokal: Bahasa Indonesia, timezone Jakarta, dan solo finance tracking.</p>
          </article>
          <article class="glass-card rounded-[2rem] p-5">
            <p class="text-sm font-semibold uppercase tracking-[0.22em] text-primary/70">Cloudflare native</p>
            <p class="mt-3 text-3xl font-bold">SSR cepat di Workers, data di D1.</p>
            <p class="mt-2 text-sm text-muted-foreground">KV dipakai buat cache ringkasan dan throttle login, bukan jadi sumber data utama.</p>
          </article>
        </div>
      </section>
    </div>
  </main>
</BaseLayout>
