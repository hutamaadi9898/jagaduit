---
const {
  title = "Data belum bisa dimuat",
  message = "Koneksi ke data sedang bermasalah. Coba muat ulang beberapa saat lagi.",
  href = Astro.url.pathname,
  actionLabel = "Coba lagi"
} = Astro.props;
---

<div class="rounded-[1.8rem] border border-destructive/20 bg-white/90 p-5 shadow-[0_18px_40px_rgba(65,43,28,0.08)]">
  <p class="text-sm font-semibold uppercase tracking-[0.22em] text-destructive/80">Mode aman</p>
  <h2 class="mt-3 text-2xl font-bold text-foreground">{title}</h2>
  <p class="mt-2 max-w-xl text-sm text-muted-foreground">{message}</p>
  <a class="mt-5 inline-flex rounded-full bg-foreground px-4 py-2 text-sm font-semibold text-white" href={href}>
    {actionLabel}
  </a>
</div>
